# ==============================================================================
# CloudHub Storage Gateway - Environment Configuration
# Copy this file to .env and update values for your environment
# ==============================================================================

# --- Database ---
POSTGRES_PASSWORD=my_secure_db_password
DATABASE_URL=postgres://postgres:my_secure_db_password@postgres:5432/storage_gateway?sslmode=disable

# --- Redis ---
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# --- Security ---
# IMPORTANT: Change these in production!
# Generate JWT_SECRET:    openssl rand -base64 32
# Generate ENCRYPT_KEY:   openssl rand -base64 24 | head -c 32
JWT_SECRET=replace_with_random_string_at_least_32_chars
ENCRYPTION_KEY=replace_with_exactly_32_characters!

# --- Server ---
PORT=8080
ENVIRONMENT=production

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# --- App URLs (for VPS/headless deployment) ---
# Base URL of the frontend app (used for shared links)
APP_BASE_URL=http://localhost:3000
# Host that rclone's OAuth callback listens on (use your VPS IP for remote access)
OAUTH_REDIRECT_HOST=127.0.0.1
