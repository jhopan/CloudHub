# Storage Gateway - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=***secure_db_password_here
DB_NAME=storage_gateway
DB_SSLMODE=disable

# Full database URL (constructed from above values)
DATABASE_URL=postgres://$DB_USER:$DB_PASSWORD@$DB_HOST:$DB_PORT/$DB_NAME?sslmode=$DB_SSLMODE

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_j...t_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# ENCRYPTION
# =============================================================================
# AES-256-GCM key for encrypting provider credentials
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
BACKEND_PORT=8080
FRONTEND_PORT=3000
ENVIRONMENT=development

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================
# Google Drive OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/providers/gdrive/oauth/callback

# Microsoft OneDrive OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8080/api/v1/providers/onedrive/oauth/callback

# Dropbox OAuth
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:8080/api/v1/providers/dropbox/oauth/callback

# =============================================================================
# RCLONE CONFIGURATION
# =============================================================================
RCLONE_PATH=/usr/bin/rclone
RCLONE_CONFIG_PATH=/etc/rclone/rclone.conf

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================
# Background worker intervals in seconds
WORKER_CAPACITY_REFRESH_INTERVAL=900    # 15 minutes
WORKER_HEALTH_CHECK_INTERVAL=300         # 5 minutes
WORKER_RETRY_TRANSFER_INTERVAL=600       # 10 minutes
WORKER_ORPHAN_CLEANUP_INTERVAL=3600      # 1 hour

# =============================================================================
# UPLOAD CONFIGURATION
# =============================================================================
MAX_UPLOAD_SIZE=10737418240              # 10 GB in bytes
UPLOAD_CONCURRENCY=10

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=true
