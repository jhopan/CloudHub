# ==============================================================================
# CloudHub Storage Gateway - Manual Deployment Environment
# Copy this file to .env.manual in the project root for bare-metal/VPS deployment
# ==============================================================================

# --- Exposed Ports ---
FRONTEND_PORT=3434
BACKEND_PORT=8989

# --- Database ---
DATABASE_URL=postgresql://postgres:***@localhost:5432/cloudhub_manual

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Security ---
# IMPORTANT: Change this in production!
# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-random-secret

# --- Encryption (must be exactly 32 characters) ---
ENCRYPTION_KEY=CloudHub32CharEncryptionKey2026X

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:${BACKEND_PORT}/api/v1
