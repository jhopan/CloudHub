# ==============================================================================
# CloudHub Storage Gateway - Docker Deployment Environment
# Copy this file to .env.docker in the project root for Docker Compose deployment
# ==============================================================================

# --- Exposed Ports (host-side mapping) ---
FRONTEND_PORT=3333
BACKEND_PORT=8888

# --- Database ---
DATABASE_URL=postgresql://postgres:***@postgres:5432/cloudhub

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Security ---
# IMPORTANT: Change this in production!
# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-random-secret

# --- Encryption (must be exactly 32 characters) ---
ENCRYPTION_KEY=CloudHub32CharEncryptionKey2026X

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:${BACKEND_PORT}/api/v1
